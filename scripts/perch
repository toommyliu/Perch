#!/usr/bin/env bash
set -euo pipefail

PROJECT="Perch.xcodeproj"
SCHEME="Perch"
APP_NAME="Perch"
PRODUCTION_BUNDLE_ID="com.app.perch"
DEVELOPMENT_BUNDLE_ID="com.app.perch.dev"
ARTIFACT_BUILD_BUNDLE_ID="com.app.perch.build"
DERIVED_DATA_PATH="build/DerivedData"
ARTIFACTS_DIR="build/artifacts"

usage() {
  cat <<'USAGE'
Usage: scripts/perch <command>

Commands:
  debug       Build Debug and launch Perch.app
  release     Build Release and launch Perch.app
  artifact    Clean-build Release and create a zipped .app artifact
  help        Show this help

Outputs:
  Debug app:      build/DerivedData/Build/Products/Debug/Perch.app
  Release app:    build/DerivedData/Build/Products/Release/Perch.app
  Artifacts:      build/artifacts/Perch-<version>-<build>-<timestamp>.zip
USAGE
}

repo_root() {
  cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd
}

require_xcodebuild() {
  if ! command -v xcodebuild >/dev/null 2>&1; then
    echo "error: xcodebuild is required. Install Xcode or Xcode Command Line Tools." >&2
    exit 1
  fi
}

build_app() {
  local configuration="$1"
  local bundle_identifier="${2:-$PRODUCTION_BUNDLE_ID}"

  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$configuration" \
    -derivedDataPath "$DERIVED_DATA_PATH" \
    "PRODUCT_BUNDLE_IDENTIFIER=$bundle_identifier" \
    build
}

clean_build_app() {
  local configuration="$1"
  local bundle_identifier="${2:-$PRODUCTION_BUNDLE_ID}"

  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$configuration" \
    -derivedDataPath "$DERIVED_DATA_PATH" \
    "PRODUCT_BUNDLE_IDENTIFIER=$bundle_identifier" \
    clean build
}

app_path() {
  local configuration="$1"
  printf '%s/%s/Build/Products/%s/%s.app' "$(repo_root)" "$DERIVED_DATA_PATH" "$configuration" "$APP_NAME"
}

launch_app() {
  local app="$1"
  if [[ ! -d "$app" ]]; then
    echo "error: app not found at $app" >&2
    exit 1
  fi

  # Quit only an already-running copy from this build path. Quitting by app
  # display name can terminate /Applications/Perch.app instead.
  quit_app_at_path "$app"
  warn_if_other_perch_instance_is_running
  open -n "$app"
  echo "Launched $app"
}

escape_extended_regex() {
  printf '%s' "$1" | sed -e 's/[][(){}.^$*+?|\\]/\\&/g'
}

quit_app_at_path() {
  local app="$1"
  local executable="$app/Contents/MacOS/$APP_NAME"
  local escaped_executable pattern

  if [[ ! -x "$executable" ]]; then
    return
  fi

  escaped_executable="$(escape_extended_regex "$executable")"
  pattern="^$escaped_executable([[:space:]]|$)"

  if ! pgrep -f "$pattern" >/dev/null 2>&1; then
    return
  fi

  pkill -TERM -f "$pattern" >/dev/null 2>&1 || true

  for _ in {1..50}; do
    if ! pgrep -f "$pattern" >/dev/null 2>&1; then
      return
    fi

    sleep 0.1
  done

  echo "warning: existing app at $app did not exit; the new launch may reuse or ignore it" >&2
}

warn_if_other_perch_instance_is_running() {
  local escaped_app_name pattern

  escaped_app_name="$(escape_extended_regex "$APP_NAME")"
  pattern="/$escaped_app_name\\.app/Contents/MacOS/$escaped_app_name([[:space:]]|$)"

  if pgrep -f "$pattern" >/dev/null 2>&1; then
    echo "warning: another Perch instance is still running; the built app may exit because Perch uses a single-instance lock" >&2
  fi
}

bundle_value() {
  local app="$1"
  local key="$2"
  /usr/libexec/PlistBuddy -c "Print :$key" "$app/Contents/Info.plist" 2>/dev/null || true
}

create_artifact() {
  local app="$1"
  mkdir -p "$ARTIFACTS_DIR"

  local version build timestamp artifact staging_dir artifact_app
  version="$(bundle_value "$app" CFBundleShortVersionString)"
  build="$(bundle_value "$app" CFBundleVersion)"
  timestamp="$(date +%Y%m%d-%H%M%S)"

  [[ -n "$version" ]] || version="0.0"
  [[ -n "$build" ]] || build="0"

  staging_dir="$(mktemp -d "${TMPDIR:-/tmp}/perch-artifact.XXXXXX")"
  artifact_app="$staging_dir/$APP_NAME.app"
  ditto "$app" "$artifact_app"
  prepare_production_artifact_app "$artifact_app"

  artifact="$ARTIFACTS_DIR/$APP_NAME-$version-$build-$timestamp.zip"
  ditto -c -k --keepParent "$artifact_app" "$artifact"
  echo "Created $artifact"
  echo "Artifact bundle id: $(bundle_value "$artifact_app" CFBundleIdentifier)"
}

prepare_production_artifact_app() {
  local app="$1"

  /usr/libexec/PlistBuddy -c "Set :CFBundleIdentifier $PRODUCTION_BUNDLE_ID" "$app/Contents/Info.plist"
  codesign \
    --force \
    --sign - \
    --options runtime \
    --entitlements "Perch/Perch.entitlements" \
    --timestamp=none \
    "$app"
}

main() {
  cd "$(repo_root)"
  require_xcodebuild

  case "${1:-help}" in
    debug)
      build_app Debug "$DEVELOPMENT_BUNDLE_ID"
      launch_app "$(app_path Debug)"
      ;;
    release)
      build_app Release "$DEVELOPMENT_BUNDLE_ID"
      launch_app "$(app_path Release)"
      ;;
    artifact)
      clean_build_app Release "$ARTIFACT_BUILD_BUNDLE_ID"
      create_artifact "$(app_path Release)"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
