#!/usr/bin/env bash
set -euo pipefail

PROJECT="Perch.xcodeproj"
SCHEME="Perch"
APP_NAME="Perch"
PRODUCTION_BUNDLE_ID="com.app.perch"
DEBUG_BUNDLE_ID="com.app.perch.debug"
ARTIFACT_BUILD_BUNDLE_ID="com.app.perch.build"
ARTIFACT_DERIVED_DATA_PATH="build/ArtifactDerivedData"
ARTIFACTS_DIR="build/artifacts"

usage() {
  cat <<'USAGE'
Usage: scripts/perch <command> [app arguments...]

Commands:
  debug       Build Debug and launch Perch.app
  release     Build Release and launch Perch.app
  logs        Build and launch Debug, then stream Perch's unified logs
  stop        Stop debug, release, or all running Perch variants
  artifact    Clean-build Release and create a zipped .app artifact
  help        Show this help

Outputs:
  Debug/Release:  Xcode's active DerivedData product location
  Artifacts:      build/artifacts/Perch-<version>-<build>-<timestamp>.zip
USAGE
}

repo_root() {
  cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd
}

require_xcodebuild() {
  if ! command -v xcodebuild >/dev/null 2>&1; then
    echo "error: xcodebuild is required. Install Xcode or Xcode Command Line Tools." >&2
    exit 1
  fi
}

build_app() {
  local configuration="$1"

  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$configuration" \
    build
}

clean_build_artifact_app() {
  local configuration="$1"
  local bundle_identifier="${2:-$PRODUCTION_BUNDLE_ID}"

  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$configuration" \
    -derivedDataPath "$ARTIFACT_DERIVED_DATA_PATH" \
    "PRODUCT_BUNDLE_IDENTIFIER=$bundle_identifier" \
    clean build
}

app_path() {
  local configuration="$1"
  local build_settings target_build_dir full_product_name

  build_settings="$(
    xcodebuild \
      -project "$PROJECT" \
      -scheme "$SCHEME" \
      -configuration "$configuration" \
      -showBuildSettings
  )"
  target_build_dir="$(awk -F ' = ' '/^[[:space:]]*TARGET_BUILD_DIR = / { print $2; exit }' <<<"$build_settings")"
  full_product_name="$(awk -F ' = ' '/^[[:space:]]*FULL_PRODUCT_NAME = / { print $2; exit }' <<<"$build_settings")"

  if [[ -z "$target_build_dir" || -z "$full_product_name" ]]; then
    echo "error: unable to resolve Xcode's product location for $configuration" >&2
    exit 1
  fi

  printf '%s/%s' "$target_build_dir" "$full_product_name"
}

artifact_app_path() {
  printf '%s/%s/Build/Products/Release/%s.app' \
    "$(repo_root)" "$ARTIFACT_DERIVED_DATA_PATH" "$APP_NAME"
}

launch_app() {
  local app="$1"
  shift
  if [[ ! -d "$app" ]]; then
    echo "error: app not found at $app" >&2
    exit 1
  fi

  quit_running_variant "$app"
  if (( $# > 0 )); then
    open "$app" --args "$@"
  else
    open "$app"
  fi

  local executable="$app/Contents/MacOS/$APP_NAME"
  local escaped_executable pattern
  escaped_executable="$(escape_extended_regex "$executable")"
  pattern="^$escaped_executable([[:space:]]|$)"

  for _ in {1..30}; do
    if pgrep -f "$pattern" >/dev/null 2>&1; then
      echo "Launched $app"
      return
    fi

    sleep 0.1
  done

  echo "error: $app did not remain running" >&2
  exit 1
}

escape_extended_regex() {
  printf '%s' "$1" | sed -e 's/[][(){}.^$*+?|\\]/\\&/g'
}

quit_running_variant() {
  local app="$1"
  local bundle_identifier

  bundle_identifier="$(bundle_value "$app" CFBundleIdentifier)"
  [[ -n "$bundle_identifier" ]] || return 0

  quit_running_bundle_identifier "$bundle_identifier"
}

quit_running_bundle_identifier() {
  local bundle_identifier="$1"
  local escaped_app_name process_pattern
  local pid executable running_app running_bundle_identifier parent_pid parent_command

  escaped_app_name="$(escape_extended_regex "$APP_NAME")"
  process_pattern="/$escaped_app_name\\.app/Contents/MacOS/$escaped_app_name([[:space:]]|$)"

  while IFS= read -r pid; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    executable="$(
      lsof -a -p "$pid" -d txt -Fn 2>/dev/null \
        | sed -n 's#^n\(.*\/'"$APP_NAME"'\.app/Contents/MacOS/'"$APP_NAME"'\)$#\1#p' \
        | sed -n '1p'
    )"
    [[ -n "$executable" ]] || continue

    running_app="${executable%/Contents/MacOS/$APP_NAME}"
    running_bundle_identifier="$(bundle_value "$running_app" CFBundleIdentifier)"
    [[ "$running_bundle_identifier" == "$bundle_identifier" ]] || continue

    parent_pid="$(ps -p "$pid" -o ppid= | tr -d '[:space:]')"
    parent_command="$(ps -p "$parent_pid" -o command= 2>/dev/null || true)"
    if [[ "$parent_command" == *debugserver* ]]; then
      echo "error: Xcode is already running $bundle_identifier from $running_app (PID $pid). Stop the active Xcode run first." >&2
      exit 1
    fi

    echo "Stopping existing $bundle_identifier process $pid from $running_app"
    kill -TERM "$pid"
    for _ in {1..50}; do
      if ! kill -0 "$pid" >/dev/null 2>&1; then
        break
      fi

      sleep 0.1
    done

    if kill -0 "$pid" >/dev/null 2>&1; then
      echo "error: existing $bundle_identifier process $pid did not exit" >&2
      exit 1
    fi
  done < <(pgrep -f "$process_pattern" 2>/dev/null || true)

  return 0
}

stop_variants() {
  case "${1:-}" in
    debug)
      quit_running_bundle_identifier "$DEBUG_BUNDLE_ID"
      ;;
    release)
      quit_running_bundle_identifier "$PRODUCTION_BUNDLE_ID"
      ;;
    all)
      quit_running_bundle_identifier "$DEBUG_BUNDLE_ID"
      quit_running_bundle_identifier "$PRODUCTION_BUNDLE_ID"
      ;;
    *)
      echo "error: stop requires debug, release, or all" >&2
      exit 2
      ;;
  esac
}

bundle_value() {
  local app="$1"
  local key="$2"
  /usr/libexec/PlistBuddy -c "Print :$key" "$app/Contents/Info.plist" 2>/dev/null || true
}

create_artifact() {
  local app="$1"
  mkdir -p "$ARTIFACTS_DIR"

  local version build timestamp artifact staging_dir artifact_app
  version="$(bundle_value "$app" CFBundleShortVersionString)"
  build="$(bundle_value "$app" CFBundleVersion)"
  timestamp="$(date +%Y%m%d-%H%M%S)"

  [[ -n "$version" ]] || version="0.0"
  [[ -n "$build" ]] || build="0"

  staging_dir="$(mktemp -d "${TMPDIR:-/tmp}/perch-artifact.XXXXXX")"
  artifact_app="$staging_dir/$APP_NAME.app"
  ditto "$app" "$artifact_app"
  prepare_production_artifact_app "$artifact_app"

  artifact="$ARTIFACTS_DIR/$APP_NAME-$version-$build-$timestamp.zip"
  ditto -c -k --keepParent "$artifact_app" "$artifact"
  echo "Created $artifact"
  echo "Artifact bundle id: $(bundle_value "$artifact_app" CFBundleIdentifier)"
}

prepare_production_artifact_app() {
  local app="$1"

  /usr/libexec/PlistBuddy -c "Set :CFBundleIdentifier $PRODUCTION_BUNDLE_ID" "$app/Contents/Info.plist"
  codesign \
    --force \
    --sign - \
    --options runtime \
    --entitlements "Perch/Perch.entitlements" \
    --timestamp=none \
    "$app"
}

main() {
  cd "$(repo_root)"

  case "${1:-help}" in
    debug)
      require_xcodebuild
      quit_running_bundle_identifier "$DEBUG_BUNDLE_ID"
      build_app Debug
      launch_app "$(app_path Debug)" "${@:2}"
      ;;
    release)
      require_xcodebuild
      quit_running_bundle_identifier "$PRODUCTION_BUNDLE_ID"
      build_app Release
      launch_app "$(app_path Release)" "${@:2}"
      ;;
    logs)
      require_xcodebuild
      quit_running_bundle_identifier "$DEBUG_BUNDLE_ID"
      build_app Debug
      launch_app "$(app_path Debug)"
      exec /usr/bin/log stream \
        --info \
        --style compact \
        --predicate "subsystem == \"$DEBUG_BUNDLE_ID\""
      ;;
    stop)
      stop_variants "${2:-}"
      ;;
    artifact)
      require_xcodebuild
      clean_build_artifact_app Release "$ARTIFACT_BUILD_BUNDLE_ID"
      create_artifact "$(artifact_app_path)"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
